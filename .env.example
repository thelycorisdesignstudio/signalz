# ============ MongoDB ============
MONGODB_URI="mongodb://127.0.0.1:27017/signalz"

# ============ AI Models (3-way race: Sonnet → Kimi → GPT) ============
# Primary: Anthropic Claude Sonnet 4.6 via Azure AI Foundry
ANTHROPIC_API_KEY="your-anthropic-api-key"
ANTHROPIC_ENDPOINT="https://your-resource.openai.azure.com/anthropic"
ANTHROPIC_DEPLOYMENT="claude-sonnet-4-6-1"

# Secondary: Kimi K2.5 via Azure
AZURE_OPENAI_API_KEY="your-azure-openai-key"
AZURE_OPENAI_ENDPOINT="https://your-resource.services.ai.azure.com"
AZURE_OPENAI_DEPLOYMENT="Kimi-K2.5"

# Tertiary: GPT-5.2 via Azure (optional fallback)
AZURE_FALLBACK_API_KEY=""
AZURE_FALLBACK_ENDPOINT=""
AZURE_FALLBACK_MODEL="gpt-5.2-codex"

# ============ Auth ============
JWT_SECRET="change-this-to-a-random-secret-in-production"

# ============ Optional ============
# LinkedIn full profile parsing (https://nubela.co/proxycurl/)
PROXYCURL_API_KEY=""

# App URL for magic links and password resets
APP_URL="http://localhost:5000"

# Port
PORT=5000
